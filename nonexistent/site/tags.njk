---
layout: layouts/base.njk
title: "Tags"
---

<h2>Tags</h2>
<ul>
  {# Render tag index pages. Each item links to a tag page. #}
  {% for tag in collections.tags | default([]) %}
    <li>
      <a href="{{ tag.url }}">{{ tag.data.title or tag.data.name or tag.fileSlug }}</a>
    </li>
  {% endfor %}
</ul>

{% if pagination %}
  <nav aria-label="Pagination">
    {% if pagination.href.previous %}
      <a href="{{ pagination.href.previous }}">Previous</a>
    {% endif %}
    {% if pagination.href.next %}
      <a href="{{ pagination.href.next }}">Next</a>
    {% endif %}
  </nav>
{% endif %}
