S3_FORCE_PATH_STYLE=false

# SFTP (for media reupload)
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=

# Logging
UNPRESS_SILENT=false
