{
  "name": "@selfagency/unpress",
  "version": "0.1.0",
  "description": "WordPress to 11ty conversion tool",
  "keywords": [],
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.build.json",
    "postbuild": "node scripts/write-dist-package.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --no-error-on-unmatched-pattern .",
    "format:check": "oxfmt --check .",
    "lint:md": "rumdl check .",
    "lint:md:fix": "rumdl check --fix . && rumdl fmt ."
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rumdl": "^0.1.80",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitepress": "^1.6.4",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yaml,yml}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{md,markdown,mdown,mkdn,mdx}": [
      "rumdl check --fix",
      "rumdl fmt"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}