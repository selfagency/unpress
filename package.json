{
  "name": "@selfagency/unpress",
  "version": "0.1.0",
  "description": "WordPress to 11ty conversion tool",
  "keywords": [],
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "bin": {
    "unpress": "./dist/bin/cli.js"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build && pnpm run build:cli && tsc -p tsconfig.build.json",
    "build:cli": "tsup bin/cli.ts --format esm --platform node --target node18 --out-dir dist/bin --sourcemap && bash scripts/add-shebang.sh dist/bin/cli.js",
    "postbuild": "node scripts/write-dist-package.js",
    "dev:cli": "tsx bin/cli.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt --no-error-on-unmatched-pattern .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:md": "rumdl check .",
    "lint:md:fix": "rumdl check --fix . && rumdl fmt .",
    "prepare": "husky",
    "test": "vitest run",
    "test:e2e:wordpress": "RUN_WORDPRESS_E2E=1 vitest run tests/e2e-wordpress.live.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@inquirer/confirm": "^6.0.12",
    "@inquirer/input": "^5.0.12",
    "@inquirer/password": "^5.0.12",
    "@inquirer/prompts": "^8.4.2",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "5.7.2",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "node-fetch": "^3.3.2",
    "p-queue": "9.1.2",
    "ssh2-sftp-client": "12.1.1",
    "turndown": "^7.2.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pa11y": "9.1.1",
    "rumdl": "^0.1.81",
    "tsup": "^6.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "4.1.5",
    "wait-on": "9.0.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yaml,yml}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{md,markdown,mdown,mkdn,mdx}": [
      "rumdl check --fix",
      "rumdl fmt"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
